<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>WslAutoCompact</AssemblyName>
    <RootNamespace>WslAutoCompact</RootNamespace>
    <Version>0.1.0</Version>
    <Authors>WSL Auto Compact contributors</Authors>
    <Description>Simple GUI wrapper for compacting WSL2 ext4.vhdx files.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

</Project>
